# Backend (raiz). Copie para .env e preencha. NUNCA commitar o .env (está no .gitignore).
# O SteamID64 é informado por request (na Home do frontend), não aqui.
# As variáveis do frontend ficam em frontend/.env (ver frontend/.env.example).
STEAM_API_KEY=

# dev | prod — em prod, /docs e /openapi.json não são expostos.
ENVIRONMENT=dev

# Só no deploy split (SPA na Vercel × API em outro host). Em dev deixe vazio:
# o proxy do Vite torna tudo same-origin e nenhum CORS é necessário.
# Ex. em prod: CORS_ORIGINS=https://seu-app.vercel.app
CORS_ORIGINS=

# Opcionais (defaults entre parênteses)
# UVICORN_LOG_LEVEL=info    # (info) lido pelo uvicorn; não habilite DEBUG no httpx (vaza a key)
# STEAM_CONCURRENCY=5
# HTTP_TIMEOUT=10.0

# Teto de saída para a Steam, protegendo a quota da STEAM_API_KEY (~100k/dia).
# O burst absorve o load de uma biblioteca grande (1 chamada de conquistas por
# jogo); a taxa sustenta o orçamento diário. Estourou → 429 ao cliente.
# STEAM_RATE_PER_MINUTE=70.0
# STEAM_RATE_BURST=500

# --- IA (dica de conquista) --------------------------------------------------
# Provedor ativo. Um por vez — fallback automático é outra feature.
# Só a chave do provedor ATIVO é obrigatória: o app falha no boot sem ela, e
# sobe normalmente sem a do outro.
AI_PROVIDER=anthropic

# Anthropic — custo linear (~$0,05/dica, sendo 61% só a busca web).
ANTHROPIC_API_KEY=sua_chave_anthropic_aqui
# ANTHROPIC_MODEL=claude-haiku-4-5
# ANTHROPIC_DAILY_BUDGET=3
# ANTHROPIC_OWNER_DAILY_BUDGET=3

# Gemini — ~10x mais barato neste volume: a busca tem cota gratuita de 5.000/mês
# (≈1.666 dicas). Passada a cota fica $14/1.000, MAIS caro que os $10 da
# Anthropic — por isso o teto aqui protege contra um degrau, não contra custo
# linear.
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3.1-flash-lite
# GEMINI_DAILY_BUDGET=100
# GEMINI_OWNER_DAILY_BUDGET=50

# Config POR PROVEDOR e não genérica de propósito: o valor certo depende de qual
# está ativo, e nada num `AI_MODEL`/`AI_DAILY_BUDGET` genérico diria isso.
# Trocar para a Anthropic esquecendo de baixar um teto calibrado para o Gemini
# custaria centenas de dólares no mês.

# Teto de RAJADA, compartilhado entre provedores: protege do rate limit do
# fornecedor, não da fatura. Quem protege a fatura é o orçamento acima.
# AI_RATE_PER_MINUTE=2.0
# AI_RATE_BURST=5

# ⚠️ Os orçamentos são voláteis: reinício do processo zera o dia. Configure
# TAMBÉM um limite de gasto no console do provedor — é a única garantia que
# sobrevive a deploy, a reinício e a bug daqui.

# Seu SteamID64, para ter cota separada da dos visitantes. Vazio = sem reserva,
# e aí um visitante (ou um bot) esgotando o dia tranca VOCÊ fora do app.
# É comparado ao steamid da URL, que é forjável: quem souber o seu ID usa a sua
# reserva. Aceito porque gasta cota, não vaza dado.
OWNER_STEAMID=
