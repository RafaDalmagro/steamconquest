# Backend (raiz). Copie para .env e preencha. NUNCA commitar o .env (está no .gitignore).
# O SteamID64 é informado por request (na Home do frontend), não aqui.
# As variáveis do frontend ficam em frontend/.env (ver frontend/.env.example).
STEAM_API_KEY=sua_chave_web_api_aqui

# dev | prod — em prod, /docs e /openapi.json não são expostos.
ENVIRONMENT=dev

# Só no deploy split (SPA na Vercel × API em outro host). Em dev deixe vazio:
# o proxy do Vite torna tudo same-origin e nenhum CORS é necessário.
# Ex. em prod: CORS_ORIGINS=https://seu-app.vercel.app
CORS_ORIGINS=

# Opcionais (defaults entre parênteses)
# UVICORN_LOG_LEVEL=info    # (info) lido pelo uvicorn; não habilite DEBUG no httpx (vaza a key)
# STEAM_CONCURRENCY=5
# HTTP_TIMEOUT=10.0

# Teto de saída para a Steam, protegendo a quota da STEAM_API_KEY (~100k/dia).
# O burst absorve o load de uma biblioteca grande (1 chamada de conquistas por
# jogo); a taxa sustenta o orçamento diário. Estourou → 429 ao cliente.
# STEAM_RATE_PER_MINUTE=70.0
# STEAM_RATE_BURST=500

# --- IA (dica de conquista) --------------------------------------------------
# Obrigatória: o app não sobe sem ela, igual à STEAM_API_KEY. Falha no start é
# melhor que 500 no clique. Nunca vai para o bundle — o SPA só fala com /api.
ANTHROPIC_API_KEY=sua_chave_anthropic_aqui

# Modelo usado para gerar a dica. O payload enviado é o *mínimo* (sem thinking,
# sem effort, busca web básica), então trocar esta variável não exige mudar
# código — vale para claude-haiku-4-5, claude-sonnet-5 e claude-opus-4-8.
# Default barato de propósito: esquecer a variável não vira conta cara.
# AI_MODEL=claude-haiku-4-5

# Teto de chamadas *pagas*. Muito menor que o da Steam porque aqui o que se
# protege é fatura, não cota que renova. appid/apiname vêm da URL pública.
# AI_RATE_PER_MINUTE=10.0
# AI_RATE_BURST=20
